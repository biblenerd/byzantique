---
import '../styles/global.css';
import { ABOUT_PAGES } from '../lib/nav';

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
}
const { title, description, wide } = Astro.props;
const fullTitle = title === 'Byzantique' ? title : `${title} · Byzantique`;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <link rel="icon" href="/favicon.svg" />
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>
    <header class="topbar">
      <a class="brand" href="/">
        <svg class="glyph" viewBox="0 0 16 24" width="14" height="21" fill="none"
          stroke="currentColor" stroke-width="1.6" stroke-linecap="round"
          aria-hidden="true" focusable="false">
          <line x1="8" y1="2.5" x2="8" y2="21.5" />
          <line x1="5.5" y1="6" x2="10.5" y2="6" />
          <line x1="2.5" y1="9.5" x2="13.5" y2="9.5" />
          <line x1="5" y1="16.8" x2="11" y2="18.6" />
        </svg>
        <span>Byzantique</span>
      </a>
      <nav>
        <a href="/ot/">Old Testament</a>
        <a href="/nt/">New Testament</a>
        <a href="/lectionary/">Lectionary</a>
        <span class="has-sub">
          <a href="/about/" aria-haspopup="true">About <span aria-hidden="true">▾</span></a>
          <span class="submenu">
            {ABOUT_PAGES.map((p) => <a href={`/about/${p.slug}/`}>{p.title}</a>)}
          </span>
        </span>
      </nav>
      <span class="spacer"></span>
    </header>
    <main id="main" class={wide ? 'wide' : undefined}>
      <slot />
    </main>
    <footer class="site">
      <p>
        © 2021–{year} Byzantique · <a href="/about/texts-and-translations/">Scripture</a> · 
        Notes licensed under Creative Commons (<a href="/license/">CC&nbsp;BY-SA&nbsp;4.0</a>) ·
        <a href="/privacy/">Privacy</a>
      </p>
    </footer>

    <script>
      // Footnote tooltips: hover/focus a caller (a[href^="#fn-"]) to preview the note;
      // clicking still jumps to the note list below the text. (REQUIREMENTS.md §6)
      (() => {
        const callers = document.querySelectorAll('a[href^="#fn-"]');
        if (!callers.length) return;
        const pop = document.createElement('div');
        pop.className = 'fn-pop';
        pop.setAttribute('role', 'tooltip');
        document.body.appendChild(pop);
        let hideT;
        const place = (ref) => {
          const r = ref.getBoundingClientRect();
          const pw = pop.offsetWidth;
          const ph = pop.offsetHeight;
          let left = r.left + r.width / 2 - pw / 2;
          left = Math.max(8, Math.min(left, window.innerWidth - pw - 8));
          let top = r.top - ph - 8;
          if (top < 8) top = r.bottom + 8;
          pop.style.left = `${left}px`;
          pop.style.top = `${top}px`;
        };
        const show = (ref) => {
          const note = document.getElementById(ref.getAttribute('href').slice(1));
          if (!note) return;
          const tmp = note.cloneNode(true);
          tmp.querySelectorAll('.tn-letter').forEach((el) => el.remove());
          pop.innerHTML = tmp.innerHTML;
          pop.classList.add('show');
          place(ref);
          clearTimeout(hideT);
        };
        const hide = () => {
          hideT = setTimeout(() => pop.classList.remove('show'), 140);
        };
        callers.forEach((ref) => {
          ref.addEventListener('mouseenter', () => show(ref));
          ref.addEventListener('mouseleave', hide);
          ref.addEventListener('focus', () => show(ref));
          ref.addEventListener('blur', () => pop.classList.remove('show'));
        });
        pop.addEventListener('mouseenter', () => clearTimeout(hideT));
        pop.addEventListener('mouseleave', hide);
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') pop.classList.remove('show');
        });
      })();
    </script>
  </body>
</html>
