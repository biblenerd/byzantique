---
import '../styles/global.css';
import { ABOUT_PAGES } from '../lib/nav';

interface Props {
  title: string;
  description?: string;
  /** Content width tier. Default = prose measure; 'index' = wider for grids/tables;
   *  'reader' = widest, for the side-by-side reader. */
  width?: 'index' | 'reader';
  /** Keep the page out of search: omit it from the on-site index (Pagefind) and tell
   *  crawlers not to index it. (robots.txt + the sitemap filter cover the rest.) */
  noindex?: boolean;
}
const { title, description, width, noindex } = Astro.props;
const fullTitle = title === 'Byzantique' ? title : `${title} · Byzantique`;
const year = new Date().getFullYear();
// Absolute URLs (resolved against `site`) for social cards + canonical.
const ogImage = new URL('/og.png', Astro.site).href;
const canonical = new URL(Astro.url.pathname, Astro.site).href;

// Pagefind search filter: which part of the site this page belongs to.
const path = Astro.url.pathname;
const section = path.startsWith('/ot/')
  ? 'Old Testament'
  : path.startsWith('/nt/')
    ? 'New Testament'
    : path.startsWith('/about/')
      ? 'About'
      : 'Site';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      // Set the theme before first paint (no flash): stored choice, else system preference.
      (() => {
        try {
          const t = localStorage.getItem('theme') ||
            (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', t);
        } catch (e) {}
      })();
    </script>
    <meta name="theme-color" content="#faf8f3" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Byzantique" />
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" />
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>
    <header class="topbar">
      <a class="brand" href="/">
        <svg class="glyph" viewBox="0 0 16 24" width="14" height="21" fill="none"
          stroke="currentColor" stroke-width="1.6" stroke-linecap="round"
          aria-hidden="true" focusable="false">
          <line x1="8" y1="2.5" x2="8" y2="21.5" />
          <line x1="5.5" y1="6" x2="10.5" y2="6" />
          <line x1="2.5" y1="9.5" x2="13.5" y2="9.5" />
          <line x1="5" y1="16.8" x2="11" y2="18.6" />
        </svg>
        <span>Byzantique</span>
      </a>
      <nav>
        <a href="/ot/">Old Testament</a>
        <a href="/nt/">New Testament</a>
        <a href="/lectionary/">Lectionary</a>
        <span class="has-sub">
          <a href="/about/" aria-haspopup="true">About <span aria-hidden="true">▾</span></a>
          <span class="submenu">
            {ABOUT_PAGES.map((p) => <a href={`/about/${p.slug}/`}>{p.title}</a>)}
          </span>
        </span>
      </nav>
      <span class="spacer"></span>
      <form class="site-search" action="/search/" role="search">
        <svg class="search-ic" viewBox="0 0 24 24" width="16" height="16" fill="none"
          stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7" /><line x1="16.5" y1="16.5" x2="21" y2="21" />
        </svg>
        <input type="search" name="q" placeholder="Search…" aria-label="Search Byzantique" autocomplete="off" />
        <div class="search-dropdown" hidden role="listbox" aria-label="Search results"></div>
      </form>
      <a class="site-search-icon" href="/search/" aria-label="Search">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor"
          stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7" /><line x1="16.5" y1="16.5" x2="21" y2="21" />
        </svg>
      </a>
      <button type="button" class="theme-toggle" aria-label="Switch to dark mode" aria-pressed="false">
        <svg class="icon-moon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor"
          stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
        </svg>
        <svg class="icon-sun" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor"
          stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4.2" />
          <path d="M12 2v2.5M12 19.5V22M2 12h2.5M19.5 12H22M4.9 4.9l1.8 1.8M17.3 17.3l1.8 1.8M19.1 4.9l-1.8 1.8M6.7 17.3l-1.8 1.8" />
        </svg>
      </button>
    </header>
    <main id="main" class={width} data-pagefind-body={noindex ? undefined : true} data-pagefind-filter={`Section:${section}`}>
      <slot />
    </main>
    <footer class="site">
      <p>
        © 2021–{year} <a href="/">Byzantique</a> ·
        Notes licensed under Creative Commons (<a href="/license/">CC&nbsp;BY-SA&nbsp;4.0</a>) ·
        <a href="/privacy/">Privacy</a>
      </p>
      <a class="footer-gh" href="https://github.com/biblenerd/byzantique" target="_blank"
        rel="noopener" aria-label="Byzantique source code on GitHub">
        <svg viewBox="0 0 16 16" width="20" height="20" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38
            0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01
            1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95
            0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27
            2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82
            1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01
            2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
        </svg>
      </a>
    </footer>

    <script is:inline>
      // Dark-mode toggle. The <head> script already set data-theme before paint; this wires
      // the button, persists a manual choice, and follows the system until one is made.
      (() => {
        const btn = document.querySelector('.theme-toggle');
        if (!btn) return;
        const meta = document.querySelector('meta[name="theme-color"]');
        const COLOR = { light: '#faf8f3', dark: '#181511' };
        const apply = (t) => {
          document.documentElement.setAttribute('data-theme', t);
          btn.setAttribute('aria-pressed', String(t === 'dark'));
          btn.setAttribute('aria-label', t === 'dark' ? 'Switch to light mode' : 'Switch to dark mode');
          if (meta) meta.setAttribute('content', COLOR[t]);
        };
        apply(document.documentElement.getAttribute('data-theme') || 'light');
        btn.addEventListener('click', () => {
          const next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
          try { localStorage.setItem('theme', next); } catch (e) {}
          apply(next);
        });
        matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
          try { if (localStorage.getItem('theme')) return; } catch (err) {}
          apply(e.matches ? 'dark' : 'light');
        });
      })();
    </script>

    <script>
      // Footnote tooltips: hover/focus a caller (a[href^="#fn-"]) to preview the note;
      // clicking still jumps to the note list below the text. (REQUIREMENTS.md §6)
      (() => {
        const callers = document.querySelectorAll('a[href^="#fn-"]');
        if (!callers.length) return;
        const pop = document.createElement('div');
        pop.className = 'fn-pop';
        pop.setAttribute('role', 'tooltip');
        document.body.appendChild(pop);
        let hideT;
        const place = (ref) => {
          const r = ref.getBoundingClientRect();
          const pw = pop.offsetWidth;
          const ph = pop.offsetHeight;
          let left = r.left + r.width / 2 - pw / 2;
          left = Math.max(8, Math.min(left, window.innerWidth - pw - 8));
          let top = r.top - ph - 8;
          if (top < 8) top = r.bottom + 8;
          pop.style.left = `${left}px`;
          pop.style.top = `${top}px`;
        };
        const show = (ref) => {
          const note = document.getElementById(ref.getAttribute('href').slice(1));
          if (!note) return;
          const tmp = note.cloneNode(true);
          tmp.querySelectorAll('.tn-letter').forEach((el) => el.remove());
          pop.innerHTML = tmp.innerHTML;
          pop.classList.add('show');
          place(ref);
          clearTimeout(hideT);
        };
        const hide = () => {
          hideT = setTimeout(() => pop.classList.remove('show'), 140);
        };
        callers.forEach((ref) => {
          ref.addEventListener('mouseenter', () => show(ref));
          ref.addEventListener('mouseleave', hide);
          ref.addEventListener('focus', () => show(ref));
          ref.addEventListener('blur', () => pop.classList.remove('show'));
        });
        pop.addEventListener('mouseenter', () => clearTimeout(hideT));
        pop.addEventListener('mouseleave', hide);
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') pop.classList.remove('show');
        });
      })();
    </script>

    <script>
      // Cross-reference previews: hover a [text](ref:…) link to peek at the first verse.
      (() => {
        const links = document.querySelectorAll('a.xref[data-ref-preview]');
        if (!links.length) return;
        const pop = document.createElement('div');
        pop.className = 'fn-pop ref-pop';
        pop.setAttribute('role', 'tooltip');
        document.body.appendChild(pop);
        let hideT;
        const place = (el) => {
          const r = el.getBoundingClientRect();
          let left = r.left + r.width / 2 - pop.offsetWidth / 2;
          left = Math.max(8, Math.min(left, window.innerWidth - pop.offsetWidth - 8));
          let top = r.top - pop.offsetHeight - 8;
          if (top < 8) top = r.bottom + 8;
          pop.style.left = `${left}px`;
          pop.style.top = `${top}px`;
        };
        const show = (el) => {
          pop.textContent = el.getAttribute('data-ref-preview');
          pop.classList.add('show');
          place(el);
          clearTimeout(hideT);
        };
        const hide = () => {
          hideT = setTimeout(() => pop.classList.remove('show'), 140);
        };
        links.forEach((el) => {
          el.addEventListener('mouseenter', () => show(el));
          el.addEventListener('mouseleave', hide);
          el.addEventListener('focus', () => show(el));
          el.addEventListener('blur', () => pop.classList.remove('show'));
        });
        pop.addEventListener('mouseenter', () => clearTimeout(hideT));
        pop.addEventListener('mouseleave', hide);
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') pop.classList.remove('show');
        });
      })();
    </script>

    <script is:inline>
      // Header search: live dropdown of top results via the Pagefind JS API.
      // Enter submits the form to /search/?q=… (also the no-JS fallback).
      // The Pagefind index only exists on the built site, so this no-ops in dev.
      (() => {
        const form = document.querySelector('.site-search');
        if (!form) return;
        const input = form.querySelector('input[name="q"]');
        const panel = form.querySelector('.search-dropdown');
        let pf = null;
        let failed = false;
        let timer;

        const load = async () => {
          if (pf || failed) return pf;
          try {
            pf = await import('/pagefind/pagefind.js');
            await pf.init?.();
          } catch {
            failed = true;
          }
          return pf;
        };

        const render = (items, q) => {
          if (!items.length) {
            panel.innerHTML = '<div class="sr-empty">No matches.</div>';
          } else {
            panel.innerHTML =
              items
                .map(
                  (d) =>
                    `<a class="sr" href="${d.url}"><span class="sr-title">${
                      (d.meta && d.meta.title) || 'Result'
                    }</span><span class="sr-ex">${d.excerpt}</span></a>`,
                )
                .join('') +
              `<a class="sr-more" href="/search/?q=${encodeURIComponent(q)}">See all results →</a>`;
          }
          panel.hidden = false;
        };

        const run = async () => {
          const q = input.value.trim();
          if (q.length < 2) {
            panel.hidden = true;
            return;
          }
          const p = await load();
          if (!p) {
            panel.hidden = true;
            return;
          }
          const res = await p.search(q);
          if (input.value.trim() !== q) return; // a newer query superseded this one
          const items = await Promise.all(res.results.slice(0, 5).map((r) => r.data()));
          render(items, q);
        };

        input.addEventListener('input', () => {
          clearTimeout(timer);
          timer = setTimeout(run, 160);
        });
        input.addEventListener('focus', () => {
          if (input.value.trim().length >= 2 && panel.innerHTML) panel.hidden = false;
        });
        input.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') {
            panel.hidden = true;
            input.blur();
          }
        });
        document.addEventListener('click', (e) => {
          if (!form.contains(e.target)) panel.hidden = true;
        });
      })();
    </script>
  </body>
</html>
