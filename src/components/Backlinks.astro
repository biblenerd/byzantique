---
// "Referenced elsewhere" — notes elsewhere in the corpus that reference this chapter's
// verses (grouped by verse), or this book's whole-book notes (flat, `flat`). Collapsible
// when long. Distinct from the scripture text, authored commentary, and translator's
// notes. REQUIREMENTS.md §5.6.
import type { BacklinkGroup, Backlink } from '../lib/commentary';

interface Props {
  groups: BacklinkGroup[];
  total: number;
  flat?: boolean; // book-level: list entries without per-verse grouping
}
const { groups, total, flat = false } = Astro.props;
const collapsible = total > 5;
const verb = (k: string) => (k === 'quote' ? 'quoted in' : 'cited in');
const label = (e: Backlink) => (e.title ? e.title : `Note on ${e.src}`);
const flatEntries = groups.flatMap((g) => g.entries);
---

{groups.length > 0 && total > 0 && (
  <section class="backlinks ui" data-pagefind-ignore>
    {collapsible ? (
      <details class="backlinks-d">
        <summary>Referenced elsewhere · {total} note{total === 1 ? '' : 's'}</summary>
        {flat ? (
          <ul>
            {flatEntries.map((e) => (
              <li>{verb(e.kind)}{' '}<a href={e.href}>{label(e)}</a>{e.title && ` (${e.src})`}</li>
            ))}
          </ul>
        ) : (
          <ul>
            {groups.map((g) => (
              <li>
                <span class="bl-v">v.&nbsp;{g.verse}</span>
                {g.entries.map((e, i) => (
                  <Fragment>{i > 0 ? '; ' : ' — '}{verb(e.kind)}{' '}<a href={e.href}>{label(e)}</a>{e.title && ` (${e.src})`}</Fragment>
                ))}
              </li>
            ))}
          </ul>
        )}
      </details>
    ) : (
      <Fragment>
        <div class="col-label bl-head">Referenced elsewhere</div>
        {flat ? (
          <ul>
            {flatEntries.map((e) => (
              <li>{verb(e.kind)}{' '}<a href={e.href}>{label(e)}</a>{e.title && ` (${e.src})`}</li>
            ))}
          </ul>
        ) : (
          <ul>
            {groups.map((g) => (
              <li>
                <span class="bl-v">v.&nbsp;{g.verse}</span>
                {g.entries.map((e, i) => (
                  <Fragment>{i > 0 ? '; ' : ' — '}{verb(e.kind)}{' '}<a href={e.href}>{label(e)}</a>{e.title && ` (${e.src})`}</Fragment>
                ))}
              </li>
            ))}
          </ul>
        )}
      </Fragment>
    )}
  </section>
)}
