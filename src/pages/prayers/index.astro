---
// Prayers section landing. A small daily rule (morning + evening for now); room to grow.
// Not in the top nav by design — reached from the home Today box and the Lectionary page.
import Base from '../../layouts/Base.astro';
---

<Base title="Prayers" description="Morning and evening prayers from the Orthodox daily prayer rule.">
  <nav class="crumbs ui"><a href="/">Byzantique</a><span class="sep">›</span>Prayers</nav>
  <h1>Prayers</h1>
  <p class="subtitle">A simple daily rule: prayers for the morning and for the evening.</p>

  <ul class="prayer-list">
    <li>
      <a href="/prayers/morning/">
        <strong>Morning Prayers</strong>
        <span>On rising, to begin the day.</span>
      </a>
    </li>
    <li>
      <a href="/prayers/evening/">
        <strong>Evening Prayers</strong>
        <span>Before sleep, at the day's end.</span>
      </a>
    </li>
  </ul>
</Base>

<style>
  .prayer-list { list-style: none; padding: 0; margin: 20px 0; display: grid; gap: 12px; }
  .prayer-list a {
    display: block; padding: 14px 18px; border: 1px solid var(--rule); border-radius: 10px;
    background: var(--panel); text-decoration: none; color: var(--ink);
  }
  .prayer-list a:hover { border-color: var(--accent); }
  .prayer-list strong { display: block; color: var(--accent); font-size: 17px; }
  .prayer-list span { font-family: var(--sans); font-size: 13px; color: var(--ink-soft); }
</style>
