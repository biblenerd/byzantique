---
import Base from '../../../layouts/Base.astro';
import ChapterText from '../../../components/ChapterText.astro';
import { BOOKS, bookLabel } from '../../../lib/canon';
import { builtCodes, loadBook, isVerse, inlinePlain } from '../../../lib/texts';
import { notesForChapter, refRange, anchorBadge } from '../../../lib/commentary';
import { chapterChipGroups } from '../../../lib/lectionary';

export function getStaticPaths() {
  const built = builtCodes();
  const paths = [];
  for (const b of BOOKS.filter((bk) => built.has(bk.code))) {
    const text = loadBook(b.code)!;
    for (const c of text.chapters) {
      paths.push({
        params: { testament: b.testament, book: b.slug, chapter: String(c.number) },
        props: { book: b, chapterNumber: c.number, total: text.chapters.length },
      });
    }
  }
  return paths;
}

const { book, chapterNumber, total } = Astro.props;
const text = loadBook(book.code)!;
const chapter = text.chapters.find((c) => c.number === chapterNumber)!;
const label = bookLabel(book);
const heading = book.testament === 'ot' ? 'Old Testament' : 'New Testament';
const base = `/${book.testament}/${book.slug}`;

const prev = chapterNumber > 1 ? chapterNumber - 1 : null;
const next = chapterNumber < total ? chapterNumber + 1 : null;
const snippet = chapter.blocks
  .flatMap((b) => b.segments ?? [])
  .filter((s) => !isVerse(s))
  .map((s: any) => inlinePlain(s.t ?? ''))
  .join(' ')
  .slice(0, 150);

const notes = notesForChapter(book.code, chapterNumber);
const hasNotes = notes.length > 0;
const lectGroups = chapterChipGroups(book.code, chapterNumber);
const vnum = (c: number, v: number) => c * 1000 + v;

// Scripture attribution for this chapter's testament (TCENT is CC BY 4.0 — credit required).
const credit =
  book.testament === 'ot'
    ? { testament: 'Old Testament', title: 'Updated Brenton Septuagint', abbr: 'ENGLXXUP', anchor: 'englxxup', license: 'public domain' }
    : { testament: 'New Testament', title: 'Text-Critical English New Testament', abbr: 'TCENT', anchor: 'tcent', license: '© Robert Adam Boyd, CC BY 4.0' };
---

<Base title={`${label} ${chapterNumber}`} description={snippet} width={hasNotes ? 'reader' : undefined}>
  <nav class="crumbs ui" data-pagefind-ignore>
    <a href="/">Byzantique</a><span class="sep">›</span>
    <a href={`/${book.testament}/`}>{heading}</a><span class="sep">›</span>
    <a href={`${base}/`}>{book.name}</a><span class="sep">›</span>Chapter {chapterNumber}
  </nav>

  <h1>{book.name}{book.paren && <span class="paren ui"> ({book.paren})</span>} {chapterNumber}</h1>

  {lectGroups.length > 0 && (
    <ul class="lect-list ui" data-pagefind-ignore>
      {lectGroups.map((g) => (
        <li>
          <span class="lect-ico" aria-hidden="true">📖</span>
          <a class="lect-ref" href={g.href}>{g.ref}</a>
          {g.occasions.length <= 3 ? (
            <span class="lect-occ">
              {g.occasions.map((o, i) => (
                <Fragment>{i > 0 ? ' · ' : ''}<a class="lect-occ-link" href="/lectionary/" data-oid={o.oid}>{o.name}</a></Fragment>
              ))}
            </span>
          ) : (
            <details class="lect-occ-x">
              <summary>read at {g.occasions.length} occasions</summary>
              <span class="lect-occ-list">
                {g.occasions.map((o, i) => (
                  <Fragment>{i > 0 ? ' · ' : ''}<a class="lect-occ-link" href="/lectionary/" data-oid={o.oid}>{o.name}</a></Fragment>
                ))}
              </span>
            </details>
          )}
        </li>
      ))}
    </ul>
  )}

  {hasNotes ? (
    <div class="reader">
      <div class="reader-toolbar ui" data-pagefind-ignore>
        <span class="reader-count">{notes.length} {notes.length === 1 ? 'note' : 'notes'}</span>
        <div class="layout-toggle" role="tablist" aria-label="Reading layout">
          <button type="button" data-layout="side" class="active" aria-pressed="true">Side&#8209;by&#8209;side</button>
          <button type="button" data-layout="stacked" aria-pressed="false">Stacked</button>
        </div>
      </div>

      <div class="reader-grid">
        <section class="col col-text">
          <div class="col-text-inner">
            <div class="col-label ui">Text · {book.name} {chapterNumber}</div>
            <ChapterText chapter={chapter} chapterNumber={chapterNumber} code={book.code} />
          </div>
        </section>

        <section class="col col-notes">
          <div class="col-label ui">Commentary</div>
          {notes.map((n) => (
            <article class="note" id={`note-${n.id}`} data-from={vnum(n.anchor.sc, n.anchor.sv)} data-to={vnum(n.anchor.ec, n.anchor.ev)}>
              <span class="note-anchor ui">
                <span class="badge">{anchorBadge(n.anchor.type)}</span>
                {book.name} {refRange(n.anchor)}
              </span>
              {n.title && <h3 class="note-title">{n.title}</h3>}
              <div class="note-body" set:html={n.html} />
            </article>
          ))}
        </section>
      </div>
    </div>
  ) : (
    <ChapterText chapter={chapter} chapterNumber={chapterNumber} code={book.code} />
  )}

  <nav class="chapnav ui" data-pagefind-ignore>
    {prev ? <a href={`${base}/${prev}`}>← {chapterNumber - 1}</a> : <span class="disabled">←</span>}
    <a href={`${base}/`}>{book.name}</a>
    {next ? <a href={`${base}/${next}`}>{chapterNumber + 1} →</a> : <span class="disabled">→</span>}
  </nav>

  <p class="text-credit ui" data-pagefind-ignore>
    {credit.testament} text: <em>{credit.title}</em> ({credit.abbr}) — {credit.license}.
    {' '}<a href={`/about/texts-and-translations/#${credit.anchor}`}>Texts &amp; Translations →</a>
  </p>
</Base>

<script>
  // Side-by-side reader: layout toggle (persisted) + note↔verse highlight linking.
  // Text "holds still" (sticky) in side-by-side; no auto-scroll in v1.
  (() => {
    const reader = document.querySelector<HTMLElement>('.reader');
    if (!reader) return;

    const grid = reader.querySelector<HTMLElement>('.reader-grid')!;
    const verses = [...reader.querySelectorAll<HTMLElement>('.v[data-v]')];
    const notes = [...reader.querySelectorAll<HTMLElement>('.note')];

    // Hover a note → highlight its verses.
    notes.forEach((note) => {
      const from = +note.dataset.from!;
      const to = +note.dataset.to!;
      const set = (on: boolean) =>
        verses.forEach((v) => {
          const x = +v.dataset.v!;
          if (x >= from && x <= to) v.classList.toggle('hl', on);
        });
      note.addEventListener('mouseenter', () => set(true));
      note.addEventListener('mouseleave', () => set(false));

      // Click the note's reference → scroll the text to its first verse + flash it.
      const anchor = note.querySelector<HTMLElement>('.note-anchor');
      let flashT: number;
      anchor?.addEventListener('click', () => {
        const target = verses.find((v) => {
          const x = +v.dataset.v!;
          return x >= from && x <= to;
        });
        if (!target) return;
        target.scrollIntoView({ block: 'center', behavior: 'smooth' });
        set(true);
        clearTimeout(flashT);
        flashT = window.setTimeout(() => set(false), 1800);
      });
    });

    // Hover a verse → highlight the notes that cover it.
    verses.forEach((v) => {
      const x = +v.dataset.v!;
      const covering = notes.filter((n) => x >= +n.dataset.from! && x <= +n.dataset.to!);
      if (!covering.length) return;
      v.addEventListener('mouseenter', () => covering.forEach((n) => n.classList.add('nhl')));
      v.addEventListener('mouseleave', () => covering.forEach((n) => n.classList.remove('nhl')));
    });

    // Layout toggle, remembered across pages.
    const KEY = 'byz-layout';
    const buttons = [...reader.querySelectorAll<HTMLButtonElement>('.layout-toggle button')];
    const apply = (mode: string) => {
      grid.classList.toggle('stacked', mode === 'stacked');
      buttons.forEach((b) => {
        const on = b.dataset.layout === mode;
        b.classList.toggle('active', on);
        b.setAttribute('aria-pressed', String(on));
      });
    };
    apply(localStorage.getItem(KEY) || 'side');
    reader.querySelector('.layout-toggle')!.addEventListener('click', (e) => {
      const b = (e.target as HTMLElement).closest<HTMLButtonElement>('button');
      if (!b) return;
      localStorage.setItem(KEY, b.dataset.layout!);
      apply(b.dataset.layout!);
    });
  })();
</script>

<script>
  // Lectionary occasion → the next date it is read (depends on "today", so resolved
  // client-side). Movable days = Pascha + pdist; fixed days = next month/day.
  (() => {
    const links = [...document.querySelectorAll<HTMLAnchorElement>('.lect-occ-link[data-oid]')];
    if (!links.length) return;
    const pad = (n: number) => String(n).padStart(2, '0');
    const iso = (d: Date) => `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}`;
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    const ty = today.getFullYear();

    fetch('/data/lectionary/pascha.json')
      .then((r) => r.json())
      .then((pascha: Record<string, string>) => {
        const next = (oid: string): string | null => {
          if (oid.startsWith('md')) {
            const [m, d] = oid.slice(2).split('-').map(Number);
            for (const y of [ty, ty + 1, ty + 2]) {
              const cand = new Date(y, m - 1, d);
              if (cand >= today) return iso(cand);
            }
            return null;
          }
          if (oid.startsWith('p')) {
            const pdist = Number(oid.slice(1));
            if (pdist >= 1000) return null; // floating feasts can't be derived from Pascha alone
            let best: Date | null = null;
            for (const y of [ty - 1, ty, ty + 1, ty + 2]) {
              const p = pascha[y];
              if (!p) continue;
              const [pm, pdd] = p.split('-').map(Number);
              const cand = new Date(y, pm - 1, pdd);
              cand.setDate(cand.getDate() + pdist);
              if (cand >= today && (!best || cand < best)) best = cand;
            }
            return best ? iso(best) : null;
          }
          return null;
        };
        links.forEach((a) => {
          const d = next(a.dataset.oid!);
          if (d) a.href = `/lectionary/?date=${d}`;
          else {
            a.removeAttribute('href'); // floating/unknown: keep as plain text
            a.classList.add('lect-occ-plain');
          }
        });
      })
      .catch(() => {});
  })();
</script>
