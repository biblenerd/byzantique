---
import Base from '../../../layouts/Base.astro';
import { BOOKS, bookLabel } from '../../../lib/canon';
import { builtCodes, loadBook } from '../../../lib/texts';
import { bookNotes, refRange, anchorBadge } from '../../../lib/commentary';
import { loadBookIntro } from '../../../lib/bookintro';

export function getStaticPaths() {
  const built = builtCodes();
  return BOOKS.filter((b) => built.has(b.code)).map((b) => ({
    params: { testament: b.testament, book: b.slug },
    props: { book: b },
  }));
}

const { book } = Astro.props;
const text = loadBook(book.code)!;
const heading = book.testament === 'ot' ? 'Old Testament' : 'New Testament';
const label = bookLabel(book);
const textName =
  book.testament === 'ot'
    ? 'Updated Brenton Septuagint (ENGLXXUP)'
    : 'Text-Critical English New Testament (TCENT)';

const intro = loadBookIntro(book.code);
const notes = bookNotes(book.code);
---

<Base title={label} description={`${label} — read the text with commentary.`}>
  <nav class="crumbs ui" data-pagefind-ignore>
    <a href="/">Byzantique</a><span class="sep">›</span>
    <a href={`/${book.testament}/`}>{heading}</a><span class="sep">›</span>{label}
  </nav>
  <h1>{book.name}{book.paren && <span class="paren ui"> ({book.paren})</span>}</h1>
  <p class="subtitle">{text.chapters.length} chapters · {textName}</p>

  {intro && <div class="book-intro" set:html={intro} />}

  {notes.length > 0 && (
    <section class="commentary">
      <div class="col-label ui">Book commentary</div>
      {notes.map((n) => (
        <article class="note">
          <span class="note-anchor ui">
            <span class="badge">{anchorBadge(n.anchor.type)}</span>
            {book.name}
          </span>
          {n.title && <h3 class="note-title">{n.title}</h3>}
          <div class="note-body" set:html={n.html} />
        </article>
      ))}
    </section>
  )}

  <div class="col-label ui" data-pagefind-ignore>Chapters</div>
  <ul class="grid" data-pagefind-ignore>
    {text.chapters.map((c) => (
      <li><a href={`/${book.testament}/${book.slug}/${c.number}`}>{c.number}</a></li>
    ))}
  </ul>
</Base>
